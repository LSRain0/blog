---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import MarkdownProse from '../../components/post/MarkdownProse.astro';
import TableOfContents from '../../components/post/TableOfContents.astro';
import MobileTOC from '../../components/post/MobileTOC.astro';
import ReadingProgress from '../../components/post/ReadingProgress.astro';
import BackToTop from '../../components/post/BackToTop.astro';
import TwikooComment from '../../components/post/TwikooComment.astro';
import { getCollection, render } from 'astro:content';
import { formatDate } from '../../utils/date';
import { calculateReadingTime } from '../../utils/reading-time';
import { articleSchema, breadcrumbListSchema } from '../../utils/json-ld';
import { SITE_URL } from '../../consts';

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => !data.draft);
  return notes.map(note => ({
    params: { slug: note.id },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content, headings } = await render(note);
const readingTime = calculateReadingTime(note.body || '');

// 获取同系列笔记
const allNotes = await getCollection('notes', ({ data }) => !data.draft);
const seriesNotes = note.data.series
  ? allNotes
      .filter(n => n.data.series === note.data.series)
      .sort((a, b) => (a.data.order || 0) - (b.data.order || 0))
  : [];

const currentIndex = seriesNotes.findIndex(n => n.id === note.id);
const prevNote = currentIndex > 0 ? seriesNotes[currentIndex - 1] : null;
const nextNote = currentIndex < seriesNotes.length - 1 ? seriesNotes[currentIndex + 1] : null;

const noteUrl = `${SITE_URL}/notes/${note.id}/`;
const jsonLd = [
  articleSchema({
    title: note.data.title,
    description: note.data.description,
    url: noteUrl,
    datePublished: note.data.pubDate.toISOString(),
    dateModified: note.data.updatedDate?.toISOString(),
    image: note.data.cover ? `${SITE_URL}${note.data.cover}` : undefined,
    tags: note.data.tags,
  }),
  breadcrumbListSchema([
    { name: '首页', url: SITE_URL },
    { name: '笔记', url: `${SITE_URL}/notes/` },
    ...(note.data.seriesTitle ? [{ name: note.data.seriesTitle, url: `${SITE_URL}/notes/` }] : []),
    { name: note.data.title, url: noteUrl },
  ]),
];
---

<BaseLayout title={note.data.title} description={note.data.description} image={note.data.cover} type="article" jsonLd={jsonLd}>
  <ReadingProgress />
  <BackToTop />
  <div class="max-w-7xl mx-auto px-4 py-12">
    {/* 系列面包屑 */}
    {seriesNotes.length > 0 && (
      <nav class="mb-6 text-sm text-text-secondary" aria-label="系列导航">
        <a href="/notes/" class="hover:text-primary transition-colors">笔记</a>
        <span class="mx-2">/</span>
        <a
          href={`/notes/`}
          class="hover:text-primary transition-colors"
        >
          {note.data.seriesTitle || note.data.series}
        </a>
        <span class="mx-2">/</span>
        <span class="text-text dark:text-text-dark">第 {currentIndex + 1} 章</span>
      </nav>
    )}

    {/* 移动端目录 */}
    <MobileTOC headings={headings} />

    <div class="flex gap-8">
      {/* 左侧边栏 - 目录 */}
      <aside class="hidden lg:block w-64 flex-shrink-0">
        <div class="sticky top-24">
          <TableOfContents headings={headings} class="p-4 rounded-lg bg-surface dark:bg-surface-dark" />
        </div>
      </aside>

      {/* 主要内容 */}
      <article class:list={['flex-1 min-w-0', seriesNotes.length === 0 && 'max-w-4xl mx-auto']}>
        <header class="mb-8">
          <h1 class="text-3xl md:text-4xl font-bold mb-4">{note.data.title}</h1>
          <div class="flex flex-wrap items-center gap-3 text-sm text-text-secondary">
            <time datetime={note.data.pubDate.toISOString()}>
              {formatDate(note.data.pubDate)}
            </time>
            {note.data.updatedDate && (
              <span class="text-xs">
                (更新于 {formatDate(note.data.updatedDate)})
              </span>
            )}
            <span>· {readingTime} 分钟阅读</span>
          </div>
          {note.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-4">
              {note.data.tags.map(tag => (
                <a
                  href={`/tags/${encodeURIComponent(tag)}/`}
                  class="text-xs px-2 py-1 rounded-full bg-primary/10 text-primary hover:bg-primary/20 transition-colors"
                >
                  #{tag}
                </a>
              ))}
            </div>
          )}
        </header>

        <MarkdownProse data-pagefind-body>
          <Content />
        </MarkdownProse>

        {/* 评论区 */}
        <TwikooComment path={`/notes/${note.id}`} />

        <footer class="mt-12 pt-8 border-t border-border dark:border-border-dark">
          <nav class="flex justify-between">
            {prevNote && (
              <a
                href={`/notes/${prevNote.id}/`}
                class="text-primary hover:text-primary-dark transition-colors"
              >
                ← {prevNote.data.title}
              </a>
            )}
            {nextNote && (
              <a
                href={`/notes/${nextNote.id}/`}
                class="text-primary hover:text-primary-dark transition-colors ml-auto"
              >
                {nextNote.data.title} →
              </a>
            )}
          </nav>
        </footer>
      </article>

      {/* 右侧边栏 - 系列导航 */}
      {seriesNotes.length > 0 && (
        <aside class="hidden xl:block w-64 flex-shrink-0">
          <nav class="sticky top-24 p-4 rounded-lg bg-surface dark:bg-surface-dark">
            <h2 class="text-sm font-semibold mb-3 text-text dark:text-text-dark">
              {note.data.seriesTitle || note.data.series}
            </h2>
            <ol class="space-y-2">
              {seriesNotes.map((n, index) => (
                <li>
                  <a
                    href={`/notes/${n.id}/`}
                    class:list={[
                      'flex items-start gap-2 text-sm transition-colors',
                      n.id === note.id
                        ? 'text-primary font-medium'
                        : 'text-text dark:text-text-dark hover:text-primary'
                    ]}
                  >
                    <span class="flex-shrink-0 w-5 h-5 rounded-full bg-primary/10 text-primary text-xs flex items-center justify-center">
                      {n.data.order || index + 1}
                    </span>
                    <span class="line-clamp-2">{n.data.title}</span>
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        </aside>
      )}
    </div>
  </div>
</BaseLayout>
