---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { formatDate } from '../../utils/date';

export async function getStaticPaths() {
  const notes = await getCollection('notes', ({ data }) => !data.draft);
  return notes.map(note => ({
    params: { slug: note.id },
    props: { note },
  }));
}

const { note } = Astro.props;
const { Content, headings } = await render(note);

// 获取同系列笔记
const allNotes = await getCollection('notes', ({ data }) => !data.draft);
const seriesNotes = note.data.series
  ? allNotes
      .filter(n => n.data.series === note.data.series)
      .sort((a, b) => (a.data.order || 0) - (b.data.order || 0))
  : [];

const currentIndex = seriesNotes.findIndex(n => n.id === note.id);
const prevNote = currentIndex > 0 ? seriesNotes[currentIndex - 1] : null;
const nextNote = currentIndex < seriesNotes.length - 1 ? seriesNotes[currentIndex + 1] : null;
---

<BaseLayout title={note.data.title} description={note.data.description}>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <div class="flex flex-col lg:flex-row gap-8">
      {/* 侧边栏 - 系列导航 */}
      {seriesNotes.length > 0 && (
        <aside class="lg:w-64 flex-shrink-0">
          <nav class="sticky top-24 p-4 rounded-lg bg-surface dark:bg-surface-dark">
            <h2 class="text-sm font-semibold mb-3 text-text-secondary">
              {note.data.seriesTitle || note.data.series}
            </h2>
            <ol class="space-y-2">
              {seriesNotes.map((n, index) => (
                <li>
                  <a
                    href={`/notes/${n.id}`}
                    class:list={[
                      'flex items-start gap-2 text-sm transition-colors',
                      n.id === note.id
                        ? 'text-primary font-medium'
                        : 'text-text-secondary hover:text-primary'
                    ]}
                  >
                    <span class="flex-shrink-0 w-5 h-5 rounded-full bg-primary/10 text-xs flex items-center justify-center">
                      {n.data.order || index + 1}
                    </span>
                    <span class="line-clamp-2">{n.data.title}</span>
                  </a>
                </li>
              ))}
            </ol>
          </nav>
        </aside>
      )}

      {/* 主要内容 */}
      <article class="flex-1 min-w-0">
        <header class="mb-8">
          <h1 class="text-3xl md:text-4xl font-bold mb-4">{note.data.title}</h1>
          <div class="flex flex-wrap items-center gap-3 text-sm text-text-secondary">
            <time datetime={note.data.pubDate.toISOString()}>
              {formatDate(note.data.pubDate)}
            </time>
            {note.data.updatedDate && (
              <span class="text-xs">
                (更新于 {formatDate(note.data.updatedDate)})
              </span>
            )}
          </div>
          {note.data.tags.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-4">
              {note.data.tags.map(tag => (
                <a
                  href={`/tags/${tag}`}
                  class="text-xs px-2 py-1 rounded-full bg-surface dark:bg-surface-dark text-text-secondary hover:bg-primary/10 hover:text-primary transition-colors"
                >
                  #{tag}
                </a>
              ))}
            </div>
          )}
        </header>

        {headings.length > 0 && (
          <nav class="mb-8 p-4 rounded-lg bg-surface dark:bg-surface-dark">
            <h2 class="text-sm font-semibold mb-3">目录</h2>
            <ul class="space-y-1">
              {headings.map(heading => (
                <li style={`padding-left: ${(heading.depth - 1) * 1}rem`}>
                  <a
                    href={`#${heading.slug}`}
                    class="text-sm text-text-secondary hover:text-primary transition-colors"
                  >
                    {heading.text}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        )}

        <div class="prose prose-lg dark:prose-invert max-w-none">
          <Content />
        </div>

        <footer class="mt-12 pt-8 border-t border-border dark:border-border-dark">
          <nav class="flex justify-between">
            {prevNote && (
              <a
                href={`/notes/${prevNote.id}`}
                class="text-primary hover:text-primary-dark transition-colors"
              >
                ← {prevNote.data.title}
              </a>
            )}
            {nextNote && (
              <a
                href={`/notes/${nextNote.id}`}
                class="text-primary hover:text-primary-dark transition-colors ml-auto"
              >
                {nextNote.data.title} →
              </a>
            )}
          </nav>
        </footer>
      </article>
    </div>
  </div>
</BaseLayout>
