---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('posts', ({ data }) => !data.draft);
const notes = await getCollection('notes', ({ data }) => !data.draft);

const allTags = new Map<string, number>();
[...posts, ...notes].forEach(item => {
  item.data.tags.forEach(tag => {
    allTags.set(tag, (allTags.get(tag) || 0) + 1);
  });
});

const sortedTags = Array.from(allTags.entries()).sort((a, b) => b[1] - a[1]);
const maxCount = sortedTags.length > 0 ? sortedTags[0][1] : 1;

function getTagSize(count: number): string {
  const ratio = count / maxCount;
  if (ratio >= 0.8) return 'text-base font-semibold px-5 py-2';
  if (ratio >= 0.5) return 'text-sm font-medium px-4 py-1.5';
  if (ratio >= 0.3) return 'text-sm px-3.5 py-1.5';
  return 'text-xs px-3 py-1.5';
}
---

<BaseLayout title="标签" description="所有标签">
  <div class="max-w-4xl mx-auto px-4 py-12" data-pagefind-body>
    <h1 class="text-3xl font-bold mb-2 text-text dark:text-text-dark">标签</h1>
    <p class="text-text-secondary mb-8">共 {sortedTags.length} 个标签</p>

    <div class="flex flex-wrap gap-2.5 items-baseline">
      {sortedTags.map(([tag, count]) => (
        <a
          href={`/tags/${encodeURIComponent(tag)}/`}
          class:list={[
            'rounded-full glass hover:bg-primary/10 hover:text-primary transition-all duration-200 text-text dark:text-text-dark',
            getTagSize(count),
          ]}
        >
          #{tag}
          <span class="text-text-secondary text-xs ml-1 opacity-60">({count})</span>
        </a>
      ))}
    </div>

    {sortedTags.length === 0 && (
      <p class="text-center text-text-secondary py-12">
        还没有标签...
      </p>
    )}
  </div>
</BaseLayout>
