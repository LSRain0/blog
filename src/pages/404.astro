---
import BaseLayout from '../components/layout/BaseLayout.astro';
---

<BaseLayout title="页面未找到" description="404 - 页面未找到">
  <div class="max-w-4xl mx-auto px-4 py-24 text-center" data-pagefind-noindex>
    <h1 class="text-7xl font-bold bg-gradient-to-r from-primary via-blue-400 to-purple-400 bg-clip-text text-transparent mb-4">404</h1>
    <p class="text-xl text-text-secondary mb-8">
      抱歉，你访问的页面不存在。
    </p>
    <div class="flex justify-center gap-4">
      <a
        href="/"
        class="px-6 py-3 rounded-xl bg-primary text-white hover:bg-primary-dark transition-colors shadow-lg shadow-primary/20"
      >
        返回首页
      </a>
      <a
        href="/blog/"
        class="px-6 py-3 rounded-xl glass glass-hover text-text dark:text-text-dark transition-all duration-200"
      >
        浏览文章
      </a>
    </div>
  </div>
</BaseLayout>
