---
import BaseLayout from '../components/layout/BaseLayout.astro';
---

<BaseLayout title="页面未找到" description="404 - 页面未找到">
  <div class="max-w-4xl mx-auto px-4 py-24 text-center" data-pagefind-noindex>
    <h1 class="text-6xl font-bold text-primary mb-4">404</h1>
    <p class="text-xl text-text-secondary mb-8">
      抱歉，你访问的页面不存在。
    </p>
    <div class="flex justify-center gap-4">
      <a
        href="/"
        class="px-6 py-3 rounded-lg bg-primary text-white hover:bg-primary-dark transition-colors"
      >
        返回首页
      </a>
      <a
        href="/blog/"
        class="px-6 py-3 rounded-lg border border-border dark:border-border-dark hover:bg-surface dark:hover:bg-surface-dark transition-colors"
      >
        浏览文章
      </a>
    </div>
  </div>
</BaseLayout>
