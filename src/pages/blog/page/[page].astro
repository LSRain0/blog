---
import BaseLayout from '../../../components/layout/BaseLayout.astro';
import PostCard from '../../../components/post/PostCard.astro';
import { getCollection } from 'astro:content';

const POSTS_PER_PAGE = 10;

export async function getStaticPaths() {
  const allPosts = await getCollection('posts', ({ data }) => !data.draft);
  const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);

  return Array.from({ length: totalPages - 1 }, (_, i) => ({
    params: { page: String(i + 2) },
    props: { pageNum: i + 2 },
  }));
}

const { pageNum } = Astro.props;

const allPosts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);
const start = (pageNum - 1) * POSTS_PER_PAGE;
const posts = allPosts.slice(start, start + POSTS_PER_PAGE);
---

<BaseLayout title={`博客 - 第 ${pageNum} 页`} description={`博客文章第 ${pageNum} 页`}>
  <div class="max-w-4xl mx-auto px-4 py-12" data-pagefind-body>
    <div class="flex items-center justify-between mb-8">
      <h1 class="text-3xl font-bold text-text dark:text-text-dark">博客文章</h1>
      <span class="text-sm text-text-secondary">第 {pageNum} / {totalPages} 页</span>
    </div>

    <div class="space-y-4">
      {posts.map(post => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          updatedDate={post.data.updatedDate}
          tags={post.data.tags}
          slug={post.id}
          body={post.body}
          category={post.data.category}
        />
      ))}
    </div>

    <nav class="mt-12 flex justify-center items-center gap-2" aria-label="分页导航">
      {pageNum > 1 && (
        <a
          href={pageNum === 2 ? '/blog/' : `/blog/page/${pageNum - 1}/`}
          class="px-4 py-2 rounded-lg border border-border dark:border-border-dark hover:bg-surface dark:hover:bg-surface-dark text-text dark:text-text-dark transition-colors text-sm"
        >
          上一页
        </a>
      )}

      {Array.from({ length: totalPages }, (_, i) => i + 1).map(page => (
        <a
          href={page === 1 ? '/blog/' : `/blog/page/${page}/`}
          class:list={[
            'px-3 py-2 rounded-lg text-sm transition-colors',
            page === pageNum
              ? 'bg-primary text-white'
              : 'border border-border dark:border-border-dark hover:bg-surface dark:hover:bg-surface-dark text-text dark:text-text-dark'
          ]}
        >
          {page}
        </a>
      ))}

      {pageNum < totalPages && (
        <a
          href={`/blog/page/${pageNum + 1}/`}
          class="px-4 py-2 rounded-lg border border-border dark:border-border-dark hover:bg-surface dark:hover:bg-surface-dark text-text dark:text-text-dark transition-colors text-sm"
        >
          下一页
        </a>
      )}
    </nav>

    <div class="mt-6 text-center">
      <a href="/blog/" class="text-sm text-primary hover:text-primary-dark transition-colors">
        ← 返回博客首页
      </a>
    </div>
  </div>
</BaseLayout>
