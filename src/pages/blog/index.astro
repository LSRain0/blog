---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import PostCard from '../../components/post/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="博客" description="所有博客文章">
  <div class="max-w-4xl mx-auto px-4 py-12" data-pagefind-body>
    <h1 class="text-3xl font-bold mb-8 text-text dark:text-text-dark">博客文章</h1>

    <div class="space-y-4">
      {posts.map(post => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          updatedDate={post.data.updatedDate}
          tags={post.data.tags}
          slug={post.id}
          body={post.body}
          category={post.data.category}
        />
      ))}
    </div>

    {posts.length === 0 && (
      <p class="center text-text-secondary py-12">
        还没有文章，敬请期待...
      </p>
    )}
  </div>
</BaseLayout>
