---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import PostCard from '../../components/post/PostCard.astro';
import { getCollection } from 'astro:content';

const POSTS_PER_PAGE = 10;

const allPosts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);
const currentPage = 1;
const posts = allPosts.slice(0, POSTS_PER_PAGE);
---

<BaseLayout title="博客" description="所有博客文章">
  <div class="max-w-4xl mx-auto px-4 py-12" data-pagefind-body>
    <h1 class="text-3xl font-bold mb-8 text-text dark:text-text-dark">博客文章</h1>

    <div class="space-y-4">
      {posts.map(post => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          updatedDate={post.data.updatedDate}
          tags={post.data.tags}
          slug={post.id}
          body={post.body}
          category={post.data.category}
        />
      ))}
    </div>

    {posts.length === 0 && (
      <p class="text-center text-text-secondary py-12">
        还没有文章，敬请期待...
      </p>
    )}

    {totalPages > 1 && (
      <nav class="mt-12 flex justify-center items-center gap-2" aria-label="分页导航">
        {currentPage > 1 && (
          <a
            href={currentPage === 2 ? '/blog/' : `/blog/page/${currentPage - 1}/`}
            class="px-4 py-2 rounded-lg border border-border dark:border-border-dark hover:bg-surface dark:hover:bg-surface-dark text-text dark:text-text-dark transition-colors text-sm"
          >
            上一页
          </a>
        )}

        {Array.from({ length: totalPages }, (_, i) => i + 1).map(page => (
          <a
            href={page === 1 ? '/blog/' : `/blog/page/${page}/`}
            class:list={[
              'px-3 py-2 rounded-lg text-sm transition-colors',
              page === currentPage
                ? 'bg-primary text-white'
                : 'border border-border dark:border-border-dark hover:bg-surface dark:hover:bg-surface-dark text-text dark:text-text-dark'
            ]}
          >
            {page}
          </a>
        ))}

        {currentPage < totalPages && (
          <a
            href={`/blog/page/${currentPage + 1}/`}
            class="px-4 py-2 rounded-lg border border-border dark:border-border-dark hover:bg-surface dark:hover:bg-surface-dark text-text dark:text-text-dark transition-colors text-sm"
          >
            下一页
          </a>
        )}
      </nav>
    )}
  </div>
</BaseLayout>
