---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import PostCard from '../../components/post/PostCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths({ paginate }) {
  const POSTS_PER_PAGE = 10;
  const allPosts = (await getCollection('posts', ({ data }) => !data.draft))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  return paginate(allPosts, { pageSize: POSTS_PER_PAGE });
}

const { page } = Astro.props;
const posts = page.data;
---

<BaseLayout title="博客" description="所有博客文章">
  <div class="max-w-4xl mx-auto px-4 py-12" data-pagefind-body>
    <div class="flex items-center justify-between mb-8">
      <h1 class="text-3xl font-bold text-text dark:text-text-dark">博客文章</h1>
      {page.lastPage > 1 && (
        <span class="text-sm text-text-secondary">第 {page.currentPage} / {page.lastPage} 页</span>
      )}
    </div>

    <div class="space-y-4">
      {posts.map(post => (
        <PostCard
          title={post.data.title}
          description={post.data.description}
          pubDate={post.data.pubDate}
          updatedDate={post.data.updatedDate}
          tags={post.data.tags}
          slug={post.id}
          body={post.body}
          category={post.data.category}
        />
      ))}
    </div>

    {posts.length === 0 && (
      <p class="text-center text-text-secondary py-12">
        还没有文章，敬请期待...
      </p>
    )}

    {page.lastPage > 1 && (
      <nav class="mt-12 flex justify-center items-center gap-2" aria-label="分页导航">
        {page.url.prev && (
          <a
            href={page.url.prev}
            class="px-4 py-2 rounded-xl glass hover:bg-primary/10 hover:text-primary text-text dark:text-text-dark transition-all duration-200 text-sm"
          >
            上一页
          </a>
        )}

        {Array.from({ length: page.lastPage }, (_, i) => i + 1).map(p => (
          <a
            href={p === 1 ? '/blog/' : `/blog/page/${p}/`}
            class:list={[
              'px-3 py-2 rounded-xl text-sm transition-all duration-200',
              p === page.currentPage
                ? 'bg-primary text-white shadow-lg shadow-primary/20'
                : 'glass hover:bg-primary/10 hover:text-primary text-text dark:text-text-dark'
            ]}
          >
            {p}
          </a>
        ))}

        {page.url.next && (
          <a
            href={page.url.next}
            class="px-4 py-2 rounded-xl glass hover:bg-primary/10 hover:text-primary text-text dark:text-text-dark transition-all duration-200 text-sm"
          >
            下一页
          </a>
        )}
      </nav>
    )}
  </div>
</BaseLayout>
