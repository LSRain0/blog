---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import MarkdownProse from '../../components/post/MarkdownProse.astro';
import TableOfContents from '../../components/post/TableOfContents.astro';
import MobileTOC from '../../components/post/MobileTOC.astro';
import ReadingProgress from '../../components/post/ReadingProgress.astro';
import BackToTop from '../../components/post/BackToTop.astro';
import TwikooComment from '../../components/post/TwikooComment.astro';
import PostMeta from '../../components/post/PostMeta.astro';
import PrevNextNav from '../../components/post/PrevNextNav.astro';
import { getCollection, render } from 'astro:content';
import { calculateReadingTime } from '../../utils/reading-time';
import { articleSchema, breadcrumbListSchema } from '../../utils/json-ld';
import { SITE_URL } from '../../consts';
import 'katex/dist/katex.min.css';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const readingTime = calculateReadingTime(post.body || '');

// 获取上一篇和下一篇文章
const allPosts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const currentIndex = allPosts.findIndex(p => p.id === post.id);
const prevPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;

const postUrl = `${SITE_URL}/blog/${post.id}/`;
const jsonLd = [
  articleSchema({
    title: post.data.title,
    description: post.data.description,
    url: postUrl,
    datePublished: post.data.pubDate.toISOString(),
    dateModified: post.data.updatedDate?.toISOString(),
    image: post.data.cover ? `${SITE_URL}${post.data.cover}` : undefined,
    tags: post.data.tags,
  }),
  breadcrumbListSchema([
    { name: '首页', url: SITE_URL },
    { name: '博客', url: `${SITE_URL}/blog/` },
    { name: post.data.title, url: postUrl },
  ]),
];
---

<BaseLayout title={post.data.title} description={post.data.description} image={post.data.cover} type="article" jsonLd={jsonLd}>
  <ReadingProgress />
  <BackToTop />
  <div class="max-w-6xl mx-auto px-4 py-12">
    {/* 移动端目录 */}
    <MobileTOC headings={headings} />

    <div class="flex gap-8">
      {/* 侧边栏 - 目录 */}
      <aside class="hidden lg:block w-64 flex-shrink-0">
        <div class="sticky top-24">
          <TableOfContents headings={headings} class="p-4 rounded-xl glass" />
        </div>
      </aside>

      {/* 主要内容 */}
      <article class="flex-1 min-w-0 max-w-4xl">
        <header class="mb-8">
          <h1 class="text-3xl md:text-4xl font-bold mb-4">{post.data.title}</h1>
          <PostMeta
            pubDate={post.data.pubDate}
            updatedDate={post.data.updatedDate}
            readingTime={readingTime}
            category={post.data.category}
            tags={post.data.tags}
          />
        </header>

        <MarkdownProse data-pagefind-body>
          <Content />
        </MarkdownProse>

        {/* 评论区 */}
        <TwikooComment path={`/blog/${post.id}`} />

        {/* 上下篇导航 */}
        <PrevNextNav
          prev={prevPost ? { slug: prevPost.id, title: prevPost.data.title, basePath: '/blog' } : null}
          next={nextPost ? { slug: nextPost.id, title: nextPost.data.title, basePath: '/blog' } : null}
        />
      </article>
    </div>
  </div>
</BaseLayout>
