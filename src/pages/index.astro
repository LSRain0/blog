---
import BaseLayout from '../components/layout/BaseLayout.astro';
import PostCard from '../components/post/PostCard.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../utils/date';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const notes = (await getCollection('notes', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const projects = (await getCollection('projects'))
  .filter(p => p.data.featured)
  .slice(0, 3);

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const allNotes = await getCollection('notes', ({ data }) => !data.draft);
const allTags = [...new Set([...allPosts.flatMap(p => p.data.tags), ...allNotes.flatMap(n => n.data.tags)])];

const totalPosts = allPosts.length;
const totalNotes = allNotes.length;
const totalTags = allTags.length;
---

<BaseLayout title="首页">
  <div class="max-w-4xl mx-auto px-4 py-12 mt-6">
    <!-- Hero 区域 -->
    <section class="mb-16">
      <div class="p-8 md:p-12 rounded-2xl bg-surface dark:bg-surface-dark border border-border dark:border-border-dark">
        <div class="flex flex-col md:flex-row items-start gap-8">
          <div class="flex-1">
            <h1 class="text-4xl md:text-5xl font-bold mb-4 text-text dark:text-text-dark">
              你好，我是 <span class="text-primary">LSRain</span>
            </h1>
            <p class="text-lg md:text-xl text-text-secondary max-w-2xl mb-6">
              物理系学生，热爱数学、编程和探索世界的本质。这里记录我的学习笔记、项目实践和生活随想。
            </p>

            <!-- 统计数据 -->
            <div class="flex flex-wrap gap-6 mb-8">
              <div class="text-center">
                <div class="text-2xl font-bold text-primary">{totalPosts}</div>
                <div class="text-sm text-text-secondary">篇文章</div>
              </div>
              <div class="text-center">
                <div class="text-2xl font-bold text-primary">{totalNotes}</div>
                <div class="text-sm text-text-secondary">篇笔记</div>
              </div>
              <div class="text-center">
                <div class="text-2xl font-bold text-primary">{totalTags}</div>
                <div class="text-sm text-text-secondary">个标签</div>
              </div>
            </div>

            <!-- 搜索入口 -->
            <a
              href="/search"
              class="inline-flex items-center gap-3 px-5 py-3 rounded-xl bg-background dark:bg-background-dark border border-border dark:border-border-dark text-text-secondary hover:border-primary hover:text-primary transition-all group"
            >
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
              <span>搜索文章和笔记...</span>
              <kbd class="hidden md:inline-flex ml-4 px-2 py-0.5 text-xs rounded bg-surface dark:bg-surface-dark border border-border dark:border-border-dark text-text-secondary">
                /
              </kbd>
            </a>
          </div>

          <!-- 快速链接 -->
          <div class="flex flex-col gap-3 md:min-w-[180px]">
            <a
              href="/blog"
              class="flex items-center gap-2 px-4 py-2.5 rounded-lg bg-primary/10 text-primary hover:bg-primary/20 transition-colors text-sm font-medium"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
              </svg>
              浏览文章
            </a>
            <a
              href="/notes"
              class="flex items-center gap-2 px-4 py-2.5 rounded-lg bg-accent/10 text-accent hover:bg-accent/20 transition-colors text-sm font-medium"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
              学习笔记
            </a>
            <a
              href="/projects"
              class="flex items-center gap-2 px-4 py-2.5 rounded-lg bg-secondary/10 text-secondary hover:bg-secondary/20 transition-colors text-sm font-medium"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
              项目展示
            </a>
            <a
              href="/about"
              class="flex items-center gap-2 px-4 py-2.5 rounded-lg bg-surface dark:bg-surface-dark text-text-secondary hover:text-primary transition-colors text-sm font-medium"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
              关于我
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- 最新文章 -->
    <section class="mb-16">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-semibold text-text dark:text-text-dark">最新文章</h2>
        <a href="/blog" class="text-sm text-primary hover:text-primary-dark transition-colors">
          查看全部 &rarr;
        </a>
      </div>
      <div class="space-y-4">
        {posts.map(post => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            updatedDate={post.data.updatedDate}
            tags={post.data.tags}
            slug={post.id}
            body={post.body}
            category={post.data.category}
          />
        ))}
      </div>
    </section>

    <!-- 最新笔记 -->
    <section class="mb-16">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-semibold text-text dark:text-text-dark">最新笔记</h2>
        <a href="/notes" class="text-sm text-primary hover:text-primary-dark transition-colors">
          查看全部 &rarr;
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {notes.map(note => (
          <a
            href={`/notes/${note.id}`}
            class="group p-5 rounded-xl border border-border dark:border-border-dark bg-background dark:bg-background-dark hover:shadow-lg transition-all duration-300"
          >
            <h3 class="font-semibold mb-2 text-text dark:text-text-dark group-hover:text-primary transition-colors">
              {note.data.title}
            </h3>
            <p class="text-sm text-text-secondary line-clamp-2 mb-3">{note.data.description}</p>
            <div class="flex items-center gap-2">
              {note.data.series && (
                <span class="text-xs px-2 py-0.5 rounded-full bg-accent/10 text-accent">
                  {note.data.seriesTitle || note.data.series}
                </span>
              )}
              {note.data.tags.slice(0, 2).map(tag => (
                <span class="text-xs px-2 py-0.5 rounded-full bg-primary/10 text-primary">
                  #{tag}
                </span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- 项目展示 -->
    {projects.length > 0 && (
      <section class="mb-16">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-2xl font-semibold text-text dark:text-text-dark">项目展示</h2>
          <a href="/projects" class="text-sm text-primary hover:text-primary-dark transition-colors">
            查看全部 &rarr;
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {projects.map(project => (
            <a
              href={`/projects/${project.id}`}
              class="group p-5 rounded-xl border border-border dark:border-border-dark bg-background dark:bg-background-dark hover:shadow-lg transition-all duration-300"
            >
              <h3 class="font-semibold mb-2 text-text dark:text-text-dark group-hover:text-primary transition-colors">
                {project.data.title}
              </h3>
              <p class="text-sm text-text-secondary line-clamp-2 mb-3">{project.data.description}</p>
              <div class="flex flex-wrap gap-1">
                {project.data.techStack.slice(0, 3).map(tech => (
                  <span class="text-xs px-2 py-0.5 rounded-full bg-primary/10 text-primary">
                    {tech}
                  </span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- 标签云 -->
    {allTags.length > 0 && (
      <section>
        <h2 class="text-2xl font-semibold mb-6 text-text dark:text-text-dark">热门标签</h2>
        <div class="flex flex-wrap gap-2">
          {allTags.slice(0, 15).map(tag => (
            <a
              href={`/tags/${tag}`}
              class="px-3 py-1.5 rounded-full bg-primary/10 text-primary hover:bg-primary/20 transition-colors text-sm"
            >
              #{tag}
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>

<script>
  // 快捷键 "/" 跳转搜索
  document.addEventListener('keydown', (e) => {
    if (e.key === '/' && !['INPUT', 'TEXTAREA'].includes((e.target as HTMLElement).tagName)) {
      e.preventDefault();
      window.location.href = '/search';
    }
  });
</script>
