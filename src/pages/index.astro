---
import BaseLayout from '../components/layout/BaseLayout.astro';
import PostCard from '../components/post/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const notes = (await getCollection('notes', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const projects = (await getCollection('projects'))
  .filter(p => p.data.featured)
  .slice(0, 3);

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const allNotes = await getCollection('notes', ({ data }) => !data.draft);

const tagCountMap = new Map<string, number>();
[...allPosts, ...allNotes].forEach(item => {
  item.data.tags.forEach(tag => {
    tagCountMap.set(tag, (tagCountMap.get(tag) || 0) + 1);
  });
});
const sortedTags = Array.from(tagCountMap.entries()).sort((a, b) => b[1] - a[1]).slice(0, 15);
const maxTagCount = sortedTags.length > 0 ? sortedTags[0][1] : 1;

function getTagSize(count: number): string {
  const ratio = count / maxTagCount;
  if (ratio >= 0.8) return 'text-sm font-semibold';
  if (ratio >= 0.5) return 'text-xs font-medium';
  return 'text-xs';
}

const totalPosts = allPosts.length;
const totalNotes = allNotes.length;
const totalTags = tagCountMap.size;

const stats = [
  { value: totalPosts, label: '篇文章', color: 'text-primary' },
  { value: totalNotes, label: '篇笔记', color: 'text-blue-400' },
  { value: totalTags, label: '个标签', color: 'text-purple-400' },
];
---

<BaseLayout title="首页">
  <div class="max-w-4xl mx-auto px-4 py-12" data-pagefind-body>
    {/* Hero 区域 */}
    <section class="mb-16 animate-fade-in-up">
      <div class="p-8 md:p-12 rounded-2xl glass">
        <div class="flex flex-col md:flex-row items-start gap-8">
          <div class="flex-1">
            <h1 class="text-4xl md:text-5xl font-bold mb-4 text-text dark:text-text-dark">
              你好，我是 <span class="bg-gradient-to-r from-primary via-blue-400 to-purple-400 bg-clip-text text-transparent">LSRain</span>
            </h1>
            <p class="text-lg md:text-xl text-text-secondary max-w-2xl mb-8 leading-relaxed">
              物理系学生，热爱数学、编程和探索世界的本质。这里记录我的学习笔记、项目实践和生活随想。
            </p>

            {/* 统计数据 */}
            <div class="flex flex-wrap gap-3 mb-8">
              {stats.map(stat => (
                <div class="px-5 py-3 rounded-xl glass text-center min-w-[100px]">
                  <div class={`text-2xl font-bold ${stat.color}`}>{stat.value}</div>
                  <div class="text-xs text-text-secondary mt-0.5">{stat.label}</div>
                </div>
              ))}
            </div>

            {/* 搜索入口 */}
            <a
              href="/search/"
              class="inline-flex items-center gap-3 px-5 py-3 rounded-xl glass glass-hover group transition-all duration-200 text-text-secondary hover:text-primary"
            >
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
              </svg>
              <span>搜索文章和笔记...</span>
              <kbd class="hidden md:inline-flex ml-4 px-2 py-0.5 text-xs rounded-md bg-surface/50 dark:bg-surface-dark/50 border border-glass-border dark:border-glass-border-dark text-text-secondary">
                /
              </kbd>
            </a>
          </div>

          {/* 快速链接 */}
          <div class="flex flex-col gap-2.5 md:min-w-[180px]">
            <a
              href="/blog/"
              class="flex items-center gap-2.5 px-4 py-2.5 rounded-xl bg-primary/10 text-primary hover:bg-primary/15 hover:translate-x-0.5 transition-all duration-200 text-sm font-medium"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
              </svg>
              浏览文章
            </a>
            <a
              href="/notes/"
              class="flex items-center gap-2.5 px-4 py-2.5 rounded-xl bg-amber-500/10 text-amber-500 hover:bg-amber-500/15 hover:translate-x-0.5 transition-all duration-200 text-sm font-medium"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
              学习笔记
            </a>
            <a
              href="/projects/"
              class="flex items-center gap-2.5 px-4 py-2.5 rounded-xl bg-purple-500/10 text-purple-500 hover:bg-purple-500/15 hover:translate-x-0.5 transition-all duration-200 text-sm font-medium"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
              </svg>
              项目展示
            </a>
            <a
              href="/about/"
              class="flex items-center gap-2.5 px-4 py-2.5 rounded-xl glass glass-hover text-sm font-medium text-text-secondary hover:text-primary transition-colors duration-200"
            >
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
              </svg>
              关于我
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* 最新文章 */}
    <section class="mb-16 animate-fade-in-up stagger-1">
      <div class="flex items-center gap-3 mb-6">
        <h2 class="text-2xl font-semibold text-text dark:text-text-dark">最新文章</h2>
        <div class="flex-1 h-px bg-gradient-to-r from-border dark:from-border-dark to-transparent"></div>
        <a href="/blog/" class="text-sm text-primary hover:text-primary-dark transition-colors">
          查看全部 &rarr;
        </a>
      </div>
      <div class="space-y-4">
        {posts.map((post, i) => (
          <div class={`animate-fade-in-up stagger-${Math.min(i + 1, 5)}`}>
            <PostCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              updatedDate={post.data.updatedDate}
              tags={post.data.tags}
              slug={post.id}
              body={post.body}
              category={post.data.category}
            />
          </div>
        ))}
      </div>
    </section>

    {/* 最新笔记 */}
    <section class="mb-16 animate-fade-in-up stagger-2">
      <div class="flex items-center gap-3 mb-6">
        <h2 class="text-2xl font-semibold text-text dark:text-text-dark">最新笔记</h2>
        <div class="flex-1 h-px bg-gradient-to-r from-border dark:from-border-dark to-transparent"></div>
        <a href="/notes/" class="text-sm text-primary hover:text-primary-dark transition-colors">
          查看全部 &rarr;
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {notes.map(note => (
          <a
            href={`/notes/${note.id}/`}
            class="group p-5 rounded-xl glass glass-hover transition-all duration-200"
          >
            <h3 class="font-semibold mb-2 text-text dark:text-text-dark group-hover:text-primary transition-colors">
              {note.data.title}
            </h3>
            <p class="text-sm text-text-secondary line-clamp-2 mb-3">{note.data.description}</p>
            <div class="flex items-center gap-2">
              {note.data.series && (
                <span class="text-xs px-2 py-0.5 rounded-full bg-amber-500/10 text-amber-500">
                  {note.data.seriesTitle || note.data.series}
                </span>
              )}
              {note.data.tags.slice(0, 2).map(tag => (
                <span class="text-xs px-2 py-0.5 rounded-full bg-primary/10 text-primary">
                  #{tag}
                </span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </section>

    {/* 项目展示 */}
    {projects.length > 0 && (
      <section class="mb-16 animate-fade-in-up stagger-3">
        <div class="flex items-center gap-3 mb-6">
          <h2 class="text-2xl font-semibold text-text dark:text-text-dark">项目展示</h2>
          <div class="flex-1 h-px bg-gradient-to-r from-border dark:from-border-dark to-transparent"></div>
          <a href="/projects/" class="text-sm text-primary hover:text-primary-dark transition-colors">
            查看全部 &rarr;
          </a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {projects.map(project => (
            <a
              href={`/projects/${project.id}/`}
              class="group p-5 rounded-xl glass glass-hover transition-all duration-200"
            >
              <h3 class="font-semibold mb-2 text-text dark:text-text-dark group-hover:text-primary transition-colors">
                {project.data.title}
              </h3>
              <p class="text-sm text-text-secondary line-clamp-2 mb-3">{project.data.description}</p>
              <div class="flex flex-wrap gap-1.5">
                {project.data.techStack.slice(0, 3).map(tech => (
                  <span class="text-xs px-2 py-0.5 rounded-full bg-primary/10 text-primary">
                    {tech}
                  </span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {/* 标签云 */}
    {sortedTags.length > 0 && (
      <section class="animate-fade-in-up stagger-4">
        <h2 class="text-2xl font-semibold mb-6 text-text dark:text-text-dark">热门标签</h2>
        <div class="flex flex-wrap gap-2 items-baseline">
          {sortedTags.map(([tag, count]) => (
            <a
              href={`/tags/${encodeURIComponent(tag)}/`}
              class:list={[
                'px-3 py-1.5 rounded-full glass hover:bg-primary/10 hover:text-primary transition-all duration-200 text-text-secondary',
                getTagSize(count),
              ]}
            >
              #{tag}
              <span class="opacity-50 ml-0.5">({count})</span>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
