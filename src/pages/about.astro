---
import BaseLayout from '../components/layout/BaseLayout.astro';

const skills = [
  {
    title: '物理学',
    color: 'from-blue-500 to-cyan-500',
    icon: 'M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z',
    items: ['经典力学与分析力学', '电磁学', '热学与统计力学', '量子力学'],
  },
  {
    title: '数学',
    color: 'from-purple-500 to-pink-500',
    icon: 'M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z',
    items: ['数学分析', '线性代数', '微分方程', '概率论与数理统计'],
  },
  {
    title: '计算机科学',
    color: 'from-emerald-500 to-teal-500',
    icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
    items: ['Python / C++', 'Web 开发', '数据可视化', '算法与数据结构'],
  },
  {
    title: 'AI 相关',
    color: 'from-amber-500 to-orange-500',
    icon: 'M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z',
    items: ['Vibe Coding', 'PyTorch', 'AI Agent', 'AI for Science'],
  },
];
---

<BaseLayout title="关于" description="关于 LSRain">
  <div class="max-w-4xl mx-auto px-4 py-12" data-pagefind-body>
    <div class="prose prose-lg dark:prose-invert max-w-none">
      <h2>个人简介</h2>
      <p>
        你好！我是 <strong>LSRain</strong>，一名物理系学生。热爱数学、编程和探索世界的本质。
        我对自然科学和计算机技术都有浓厚的兴趣，喜欢用编程的思维去理解物理，也喜欢用物理的直觉去思考问题。
      </p>

      <h2>学习方向</h2>
      <div class="not-prose grid grid-cols-1 md:grid-cols-2 gap-4 my-6">
        {skills.map(skill => (
          <div class="group p-5 rounded-xl glass glass-hover transition-all duration-200">
            <div class="flex items-center gap-3 mb-3">
              <div class={`p-2 rounded-lg bg-gradient-to-br ${skill.color} text-white`}>
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={skill.icon} />
                </svg>
              </div>
              <h3 class="font-semibold text-text dark:text-text-dark">{skill.title}</h3>
            </div>
            <ul class="text-sm text-text-secondary space-y-1.5 ml-1">
              {skill.items.map(item => (
                <li class="flex items-center gap-2">
                  <span class="w-1 h-1 rounded-full bg-text-secondary/40"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>

      <h2>关于这个博客</h2>
      <p>
        这是我的个人博客，用于记录学习笔记、项目实践和生活随想。
        我相信写作是最好的学习方式之一，通过记录和分享，可以更好地理解、掌握乃至传播知识。
      </p>
      <p>
        博客主要包含以下内容：
      </p>
      <ul>
        <li><strong>博客文章</strong>：编程记录、技术分享、生活随想</li>
        <li><strong>学习笔记</strong>：物理、数学等学科的系统化笔记</li>
        <li><strong>项目展示</strong>：个人项目的设计思路和技术实现</li>
      </ul>

      <h2>技术栈</h2>
      <p>这个博客使用以下技术构建：</p>
      <ul>
        <li><a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a> — 静态站点生成框架</li>
        <li><a href="https://www.typescriptlang.org" target="_blank" rel="noopener noreferrer">TypeScript</a> — 类型安全</li>
        <li><a href="https://tailwindcss.com" target="_blank" rel="noopener noreferrer">Tailwind CSS</a> — 样式系统</li>
        <li><a href="https://katex.org" target="_blank" rel="noopener noreferrer">KaTeX</a> — 数学公式渲染</li>
        <li><a href="https://shiki.style" target="_blank" rel="noopener noreferrer">Shiki</a> — 代码高亮</li>
        <li><a href="https://pagefind.app" target="_blank" rel="noopener noreferrer">Pagefind</a> — 静态全文搜索</li>
      </ul>

      <h2>联系方式</h2>
      <ul>
        <li>GitHub: <a href="https://github.com/LSRain0" target="_blank" rel="noopener noreferrer">@LSRain0</a></li>
        <li>RSS: <a href="/rss.xml">订阅</a></li>
      </ul>

      <h2>关于内容</h2>
      <p>
        博客中的笔记和文章都是我个人学习过程的记录。如果发现错误，欢迎通过 GitHub 联系我。
      </p>
      <p>
        本站内容遵循 <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/" target="_blank" rel="noopener noreferrer">CC BY-NC-SA 4.0</a> 协议，
        转载请注明出处。
      </p>
    </div>
  </div>
</BaseLayout>
