---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="项目" description="个人项目展示">
  <div class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold mb-8">项目展示</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {projects.map(project => (
        <a
          href={`/projects/${project.id}`}
          class="group p-6 rounded-xl border border-border dark:border-border-dark hover:shadow-lg transition-all duration-300"
        >
          <div class="flex items-start justify-between mb-3">
            <h2 class="text-xl font-semibold group-hover:text-primary transition-colors">
              {project.data.title}
            </h2>
            {project.data.featured && (
              <span class="px-2 py-0.5 rounded-full bg-accent/10 text-accent text-xs">
                精选
              </span>
            )}
          </div>

          <p class="text-text-secondary mb-4 line-clamp-3">
            {project.data.description}
          </p>

          <div class="flex flex-wrap gap-2 mb-4">
            {project.data.techStack.map(tech => (
              <span class="text-xs px-2 py-1 rounded-full bg-surface dark:bg-surface-dark">
                {tech}
              </span>
            ))}
          </div>

          <div class="flex items-center gap-3 text-sm">
            {project.data.github && (
              <span class="text-text-secondary hover:text-primary transition-colors">
                GitHub →
              </span>
            )}
            {project.data.demo && (
              <span class="text-text-secondary hover:text-primary transition-colors">
                Demo →
              </span>
            )}
          </div>
        </a>
      ))}
    </div>

    {projects.length === 0 && (
      <p class="text-center text-text-secondary py-12">
        还没有项目，敬请期待...
      </p>
    )}
  </div>
</BaseLayout>
