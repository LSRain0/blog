---
import BaseLayout from '../components/layout/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../utils/date';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const notes = (await getCollection('notes', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// 合并所有内容并按年份分组
interface ArchiveItem {
  id: string;
  title: string;
  pubDate: Date;
  type: 'post' | 'note';
  series?: string;
  seriesTitle?: string;
}

const allItems: ArchiveItem[] = [
  ...posts.map(p => ({
    id: p.id,
    title: p.data.title,
    pubDate: p.data.pubDate,
    type: 'post' as const,
  })),
  ...notes.map(n => ({
    id: n.id,
    title: n.data.title,
    pubDate: n.data.pubDate,
    type: 'note' as const,
    series: n.data.series,
    seriesTitle: n.data.seriesTitle,
  })),
].sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf());

const itemsByYear = new Map<number, ArchiveItem[]>();
allItems.forEach(item => {
  const year = item.pubDate.getFullYear();
  const existing = itemsByYear.get(year) || [];
  existing.push(item);
  itemsByYear.set(year, existing);
});

const years = Array.from(itemsByYear.keys()).sort((a, b) => b - a);
---

<BaseLayout title="归档" description="文章和笔记归档">
  <div class="max-w-4xl mx-auto px-4 py-12" data-pagefind-body>
    <h1 class="text-3xl font-bold mb-2 text-text dark:text-text-dark">归档</h1>
    <p class="text-text-secondary mb-8">共 {posts.length} 篇文章，{notes.length} 篇笔记</p>

    <div class="flex gap-4 mb-8 text-sm">
      <span class="flex items-center gap-1.5">
        <span class="w-2.5 h-2.5 rounded-full bg-gradient-to-br from-primary to-blue-400"></span>
        文章
      </span>
      <span class="flex items-center gap-1.5">
        <span class="w-2.5 h-2.5 rounded-full bg-gradient-to-br from-amber-500 to-orange-400"></span>
        笔记
      </span>
    </div>

    <div class="space-y-12">
      {years.map(year => (
        <section>
          <h2 class="text-2xl font-semibold mb-5 text-text dark:text-text-dark flex items-center gap-3">
            <span>{year}</span>
            <span class="flex-1 h-px bg-gradient-to-r from-border dark:from-border-dark to-transparent"></span>
          </h2>
          <div class="relative pl-6 border-l-2 border-border/50 dark:border-border-dark/50 space-y-1">
            {itemsByYear.get(year)?.map(item => (
              <a
                href={item.type === 'post' ? `/blog/${item.id}/` : `/notes/${item.id}/`}
                class="group relative flex items-baseline gap-4 py-2.5 px-4 -ml-6 rounded-lg hover:bg-surface/30 dark:hover:bg-surface-dark/30 transition-colors duration-200"
              >
                {/* 时间线圆点 */}
                <span class:list={[
                  'absolute left-0 top-1/2 -translate-y-1/2 w-2.5 h-2.5 rounded-full border-2 border-background dark:border-background-dark z-10',
                  item.type === 'post'
                    ? 'bg-gradient-to-br from-primary to-blue-400'
                    : 'bg-gradient-to-br from-amber-500 to-orange-400',
                ]} />

                <time
                  datetime={item.pubDate.toISOString()}
                  class="text-sm text-text-secondary flex-shrink-0 w-20 pl-2"
                >
                  {item.pubDate.toLocaleDateString('zh-CN', { month: '2-digit', day: '2-digit' })}
                </time>
                <span class="group-hover:text-primary transition-colors text-text dark:text-text-dark">
                  {item.title}
                </span>
                {item.seriesTitle && (
                  <span class="text-xs px-2 py-0.5 rounded-full bg-amber-500/10 text-amber-500">
                    {item.seriesTitle}
                  </span>
                )}
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>

    {allItems.length === 0 && (
      <p class="text-center text-text-secondary py-12">
        还没有内容...
      </p>
    )}
  </div>
</BaseLayout>
