---
const navItems = [
  { href: '/', label: '首页' },
  { href: '/blog/', label: '博客' },
  { href: '/notes/', label: '笔记' },
  { href: '/projects/', label: '项目' },
  { href: '/tags/', label: '标签' },
  { href: '/archive/', label: '归档' },
  { href: '/about/', label: '关于' },
  { href: '/search/', label: '搜索' },
];

const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 bg-background/80 dark:bg-background-dark/80 backdrop-blur-sm border-b border-border dark:border-border-dark" data-pagefind-ignore>
  <nav class="max-w-4xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="text-xl font-bold text-primary hover:text-primary-dark transition-colors">
      LSRain的小屋
    </a>

    <div class="flex items-center gap-6">
      <ul class="hidden md:flex items-center gap-6">
        {navItems.map(item => (
          <li>
            <a
              href={item.href}
              class:list={[
                'text-sm font-medium transition-colors hover:text-primary',
                isActive(item.href)
                  ? 'text-primary'
                  : 'text-text-secondary dark:text-text-secondary'
              ]}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>

      <button
        id="bg-toggle"
        class="p-2 rounded-lg hover:bg-surface dark:hover:bg-surface-dark transition-colors"
        aria-label="切换背景图片"
        title="切换背景"
      >
        <svg class="w-5 h-5" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>
      </button>

      <button
        id="theme-toggle"
        class="p-2 rounded-lg hover:bg-surface dark:hover:bg-surface-dark transition-colors"
        aria-label="切换深色模式"
      >
        <svg class="w-5 h-5 hidden dark:block" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <svg class="w-5 h-5 block dark:hidden" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>

      <button
        id="mobile-menu-toggle"
        class="md:hidden p-2 rounded-lg hover:bg-surface dark:hover:bg-surface-dark transition-colors"
        aria-label="打开菜单"
      >
        <svg class="w-5 h-5" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- 移动端菜单 -->
  <div
    id="mobile-menu"
    class="md:hidden overflow-hidden transition-all duration-300 ease-in-out max-h-0 opacity-0"
  >
    <ul class="max-w-4xl mx-auto px-4 py-4 space-y-2 bg-background dark:bg-background-dark border-t border-border dark:border-border-dark">
      {navItems.map(item => (
        <li>
          <a
            href={item.href}
            class:list={[
              'mobile-menu-link block py-2 px-4 rounded-lg text-sm font-medium transition-colors',
              isActive(item.href)
                ? 'bg-primary/10 text-primary'
                : 'hover:bg-surface dark:hover:bg-surface-dark'
            ]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  function initHeader() {
    // 主题切换
    const themeToggle = document.getElementById('theme-toggle');
    const html = document.documentElement;

    if (themeToggle) {
      themeToggle.addEventListener('click', () => {
        html.classList.toggle('dark');
        localStorage.setItem('theme', html.classList.contains('dark') ? 'dark' : 'light');
      });
    }

    // 背景切换
    const bgToggle = document.getElementById('bg-toggle');
    const BG_COUNT = 17;

    if (bgToggle) {
      bgToggle.addEventListener('click', () => {
        let current = parseInt(localStorage.getItem('bg-index') || '1', 10);
        let next = current % BG_COUNT + 1;
        localStorage.setItem('bg-index', String(next));
        document.documentElement.style.setProperty('--bg-image', `url('/backgrounds/bg-${next}.jpg')`);
      });
    }

    // 移动端菜单
    const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');

    function toggleMobileMenu() {
      if (!mobileMenu) return;
      const isOpen = mobileMenu.classList.contains('max-h-0');
      if (isOpen) {
        mobileMenu.classList.remove('max-h-0', 'opacity-0');
        mobileMenu.classList.add('max-h-96', 'opacity-100');
        mobileMenuToggle?.setAttribute('aria-label', '关闭菜单');
      } else {
        mobileMenu.classList.remove('max-h-96', 'opacity-100');
        mobileMenu.classList.add('max-h-0', 'opacity-0');
        mobileMenuToggle?.setAttribute('aria-label', '打开菜单');
      }
    }

    if (mobileMenuToggle) {
      mobileMenuToggle.addEventListener('click', toggleMobileMenu);
    }

    // 点击菜单链接后自动关闭菜单
    document.querySelectorAll('.mobile-menu-link').forEach(link => {
      link.addEventListener('click', () => {
        if (mobileMenu && !mobileMenu.classList.contains('max-h-0')) {
          mobileMenu.classList.remove('max-h-96', 'opacity-100');
          mobileMenu.classList.add('max-h-0', 'opacity-0');
        }
      });
    });
  }

  // Astro 页面切换时重新初始化
  document.addEventListener('astro:page-load', initHeader);
  initHeader();
</script>
