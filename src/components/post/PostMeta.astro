---
import { formatDate } from '../../utils/date';

interface Props {
  pubDate: Date;
  updatedDate?: Date;
  readingTime?: number;
  category?: string;
  tags?: string[];
}

const { pubDate, updatedDate, readingTime, category, tags = [] } = Astro.props;
---

<div class="flex flex-wrap items-center gap-3 text-sm text-text-secondary">
  <time datetime={pubDate.toISOString()} class="flex items-center gap-1.5">
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
    </svg>
    {formatDate(pubDate)}
  </time>
  {updatedDate && (
    <span class="text-xs opacity-70">
      (更新于 {formatDate(updatedDate)})
    </span>
  )}
  {readingTime !== undefined && (
    <span class="flex items-center gap-1.5">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      {readingTime} 分钟阅读
    </span>
  )}
  {category && (
    <span class="px-2.5 py-0.5 rounded-full bg-primary/10 text-primary font-medium">
      {category}
    </span>
  )}
</div>
{tags.length > 0 && (
  <div class="flex flex-wrap gap-2 mt-4">
    {tags.map(tag => (
      <a
        href={`/tags/${encodeURIComponent(tag)}/`}
        class="text-xs px-2.5 py-1 rounded-full bg-primary/10 text-primary hover:bg-primary/15 transition-colors duration-200"
      >
        #{tag}
      </a>
    ))}
  </div>
)}
