---
// 阅读进度条组件
---

<div
  id="reading-progress"
  class="fixed left-0 h-[3px] z-[60] transition-[width] duration-150"
  style="top: 2.5rem; width: 0%; background-color: #000;"
  aria-hidden="true"
></div>

<script>
  function initReadingProgress() {
    const bar = document.getElementById('reading-progress');
    if (!bar) return;

    function updateProgress() {
      const scrollTop = window.scrollY;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      const progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
      bar.style.width = `${Math.min(progress, 100)}%`;
    }

    function updateColor() {
      const isDark = document.documentElement.classList.contains('dark');
      bar.style.backgroundColor = isDark ? '#fff' : '#6b7280';
    }

    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();
    updateColor();

    // 监听深色模式变化
    const observer = new MutationObserver(updateColor);
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
  }

  document.addEventListener('astro:page-load', initReadingProgress);
  initReadingProgress();
</script>
