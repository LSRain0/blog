---
interface Props {
  class?: string;
  [key: string]: any;
}

const { class: className, ...rest } = Astro.props;
---

<div class:list={['prose', 'prose-lg', 'dark:prose-invert', 'max-w-none', className]} {...rest}>
  <slot />
</div>

<style>
  /* 代码块样式 */
  .prose :global(pre) {
    overflow-x: auto;
    padding: 1rem;
    border-radius: 0.5rem;
  }

  /* 行内代码 */
  .prose :global(:not(pre) > code) {
    padding: 0.2em 0.4em;
    border-radius: 0.25rem;
    font-size: 0.875em;
  }

  /* 表格样式 */
  .prose :global(table) {
    overflow-x: auto;
    display: block;
  }

  /* 数学公式 */
  .prose :global(.katex-display) {
    overflow-x: auto;
    overflow-y: hidden;
    padding: 0.5rem 0;
  }

  /* 图片 */
  .prose :global(img) {
    border-radius: 0.5rem;
  }

  /* 链接 */
  .prose :global(a) {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .prose :global(a:hover) {
    text-decoration-thickness: 2px;
  }
</style>
