---
interface Props {
  class?: string;
  [key: string]: any;
}

const { class: className, ...rest } = Astro.props;
---

<div class:list={['prose', 'prose-lg', 'dark:prose-invert', 'max-w-none', className]} {...rest}>
  <slot />
</div>

<style>
  /* 代码块样式 - 玻璃效果 */
  .prose :global(pre) {
    position: relative;
    overflow-x: auto;
    padding: 1rem;
    border-radius: 0.75rem;
    background: rgba(241, 245, 249, 0.8);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(226, 232, 240, 0.5);
  }

  :global(.dark) .prose :global(pre) {
    background: rgba(30, 41, 59, 0.8);
    border-color: rgba(51, 65, 85, 0.5);
  }

  /* 行内代码 */
  .prose :global(:not(pre) > code) {
    padding: 0.2em 0.4em;
    border-radius: 0.375rem;
    font-size: 0.875em;
    background: rgba(59, 130, 246, 0.08);
    border: 1px solid rgba(59, 130, 246, 0.15);
    color: var(--color-primary);
  }

  :global(.dark) .prose :global(:not(pre) > code) {
    background: rgba(96, 165, 250, 0.1);
    border-color: rgba(96, 165, 250, 0.2);
    color: #93c5fd;
  }

  /* 表格样式 */
  .prose :global(table) {
    overflow-x: auto;
    display: block;
  }

  /* 数学公式 */
  .prose :global(.katex-display) {
    overflow-x: auto;
    overflow-y: hidden;
    padding: 0.5rem 0;
  }

  /* 图片 */
  .prose :global(img) {
    border-radius: 0.75rem;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  :global(.dark) .prose :global(img) {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.3);
  }

  /* 链接 */
  .prose :global(a) {
    text-decoration: underline;
    text-decoration-color: rgba(59, 130, 246, 0.3);
    text-underline-offset: 0.2em;
    transition: text-decoration-color 0.2s;
  }

  .prose :global(a:hover) {
    text-decoration-color: var(--color-primary);
    text-decoration-thickness: 2px;
  }

  /* 引用块 */
  .prose :global(blockquote) {
    border-left: 3px solid;
    border-image: linear-gradient(to bottom, var(--color-primary), #8b5cf6) 1;
    padding-left: 1rem;
  }

  /* 复制按钮 - 玻璃风格 */
  .prose :global(.code-copy-btn) {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    padding: 0.25rem 0.625rem;
    border-radius: 0.5rem;
    font-size: 0.75rem;
    color: #64748b;
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s, color 0.2s, background 0.2s;
  }

  :global(.dark) .prose :global(.code-copy-btn) {
    color: #94a3b8;
    background: rgba(30, 41, 59, 0.6);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .prose :global(pre:hover .code-copy-btn) {
    opacity: 1;
  }

  .prose :global(.code-copy-btn:hover) {
    color: var(--color-primary);
    background: rgba(255, 255, 255, 0.8);
  }

  :global(.dark) .prose :global(.code-copy-btn:hover) {
    color: #93c5fd;
    background: rgba(30, 41, 59, 0.8);
  }

  .prose :global(.code-copy-btn.copied) {
    color: #10b981;
  }
</style>

<script>
  function initCodeCopy() {
    document.querySelectorAll('pre').forEach(pre => {
      if (pre.querySelector('.code-copy-btn')) return;

      const btn = document.createElement('button');
      btn.className = 'code-copy-btn';
      btn.textContent = '复制';
      btn.setAttribute('aria-label', '复制代码');

      btn.addEventListener('click', async () => {
        const code = pre.querySelector('code');
        if (!code) return;
        try {
          await navigator.clipboard.writeText(code.textContent || '');
          btn.textContent = '已复制';
          btn.classList.add('copied');
          setTimeout(() => {
            btn.textContent = '复制';
            btn.classList.remove('copied');
          }, 2000);
        } catch {
          btn.textContent = '失败';
          setTimeout(() => { btn.textContent = '复制'; }, 2000);
        }
      });

      pre.appendChild(btn);
    });
  }

  document.addEventListener('astro:page-load', initCodeCopy);
  initCodeCopy();
</script>
