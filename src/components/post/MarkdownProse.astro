---
interface Props {
  class?: string;
  [key: string]: any;
}

const { class: className, ...rest } = Astro.props;
---

<div class:list={['prose', 'prose-lg', 'dark:prose-invert', 'max-w-none', className]} {...rest}>
  <slot />
</div>

<style>
  /* 代码块样式 */
  .prose :global(pre) {
    position: relative;
    overflow-x: auto;
    padding: 1rem;
    border-radius: 0.5rem;
  }

  /* 行内代码 */
  .prose :global(:not(pre) > code) {
    padding: 0.2em 0.4em;
    border-radius: 0.25rem;
    font-size: 0.875em;
  }

  /* 表格样式 */
  .prose :global(table) {
    overflow-x: auto;
    display: block;
  }

  /* 数学公式 */
  .prose :global(.katex-display) {
    overflow-x: auto;
    overflow-y: hidden;
    padding: 0.5rem 0;
  }

  /* 图片 */
  .prose :global(img) {
    border-radius: 0.5rem;
  }

  /* 链接 */
  .prose :global(a) {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  .prose :global(a:hover) {
    text-decoration-thickness: 2px;
  }

  /* 复制按钮 */
  .prose :global(.code-copy-btn) {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    padding: 0.25rem 0.5rem;
    border-radius: 0.375rem;
    font-size: 0.75rem;
    color: #9ca3af;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.1);
    cursor: pointer;
    opacity: 0;
    transition: opacity 0.2s, color 0.2s;
  }

  .prose :global(pre:hover .code-copy-btn) {
    opacity: 1;
  }

  .prose :global(.code-copy-btn:hover) {
    color: #f9fafb;
    background: rgba(255, 255, 255, 0.2);
  }

  .prose :global(.code-copy-btn.copied) {
    color: #10b981;
  }
</style>

<script>
  function initCodeCopy() {
    document.querySelectorAll('pre').forEach(pre => {
      if (pre.querySelector('.code-copy-btn')) return;

      const btn = document.createElement('button');
      btn.className = 'code-copy-btn';
      btn.textContent = '复制';
      btn.setAttribute('aria-label', '复制代码');

      btn.addEventListener('click', async () => {
        const code = pre.querySelector('code');
        if (!code) return;
        try {
          await navigator.clipboard.writeText(code.textContent || '');
          btn.textContent = '已复制';
          btn.classList.add('copied');
          setTimeout(() => {
            btn.textContent = '复制';
            btn.classList.remove('copied');
          }, 2000);
        } catch {
          btn.textContent = '失败';
          setTimeout(() => { btn.textContent = '复制'; }, 2000);
        }
      });

      pre.appendChild(btn);
    });
  }

  document.addEventListener('astro:page-load', initCodeCopy);
  initCodeCopy();
</script>
