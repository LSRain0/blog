---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  class?: string;
}

const { headings, class: className } = Astro.props;
---

{headings.length > 0 && (
  <nav class:list={['toc', className]}>
    <h2 class="text-sm font-semibold mb-3 text-text dark:text-text-dark">
      目录
    </h2>
    <ul class="space-y-1 border-l-2 border-border dark:border-border-dark">
      {headings.map(heading => (
        <li>
          <a
            href={`#${heading.slug}`}
            class:list={[
              'toc-link block text-sm transition-colors py-1 hover:text-primary',
              'border-l-2 -ml-[2px] border-transparent hover:border-primary',
            ]}
            style={`padding-left: ${(heading.depth - 1) * 0.75 + 0.75}rem`}
            data-target={heading.slug}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<script>
  function initTOC() {
    const links = document.querySelectorAll<HTMLAnchorElement>('.toc-link');
    if (links.length === 0) return;

    const headingIds = Array.from(links).map(link => link.dataset.target!);
    const headings = headingIds
      .map(id => document.getElementById(id))
      .filter(Boolean) as HTMLElement[];

    if (headings.length === 0) return;

    // 平滑滚动
    links.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const targetId = link.dataset.target;
        const target = document.getElementById(targetId!);
        if (target) {
          const offset = 80; // 顶部偏移量，避免被固定头部遮挡
          const top = target.getBoundingClientRect().top + window.scrollY - offset;
          window.scrollTo({
            top,
            behavior: 'smooth'
          });
          // 更新 URL hash
          history.pushState(null, '', `#${targetId}`);
        }
      });
    });

    function updateActiveLink() {
      const scrollY = window.scrollY + 120;

      let activeId = headingIds[0];
      for (const heading of headings) {
        if (heading.offsetTop <= scrollY) {
          activeId = heading.id;
        }
      }

      links.forEach(link => {
        const isActive = link.dataset.target === activeId;
        link.classList.toggle('text-primary', isActive);
        link.classList.toggle('font-medium', isActive);
        link.classList.toggle('text-text-secondary', !isActive);
        link.classList.toggle('border-primary', isActive);
        link.classList.toggle('border-transparent', !isActive);
      });
    }

    window.addEventListener('scroll', updateActiveLink, { passive: true });
    updateActiveLink();
  }

  // 页面加载和 Astro 页面切换时初始化
  document.addEventListener('astro:page-load', initTOC);
  initTOC();
</script>
