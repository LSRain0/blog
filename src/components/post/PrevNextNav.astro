---
interface Props {
  prev?: { slug: string; title: string; basePath: string } | null;
  next?: { slug: string; title: string; basePath: string } | null;
  prevLabel?: string;
  nextLabel?: string;
  backLink?: { href: string; label: string };
}

const {
  prev = null,
  next = null,
  prevLabel = '上一篇',
  nextLabel = '下一篇',
  backLink,
} = Astro.props;
---

<footer class="mt-12 pt-8 border-t border-border dark:border-border-dark">
  <nav class="grid grid-cols-1 md:grid-cols-2 gap-4">
    {prev && (
      <a
        href={`${prev.basePath}/${prev.slug}/`}
        class="group p-4 rounded-xl glass glass-hover transition-all duration-200"
      >
        <span class="text-xs text-text-secondary flex items-center gap-1 mb-1">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          {prevLabel}
        </span>
        <span class="text-sm font-medium text-text dark:text-text-dark group-hover:text-primary transition-colors line-clamp-1">
          {prev.title}
        </span>
      </a>
    )}
    {next && (
      <a
        href={`${next.basePath}/${next.slug}/`}
        class="group p-4 rounded-xl glass glass-hover transition-all duration-200 md:text-right md:ml-auto"
      >
        <span class="text-xs text-text-secondary flex items-center gap-1 mb-1 md:justify-end">
          {nextLabel}
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </span>
        <span class="text-sm font-medium text-text dark:text-text-dark group-hover:text-primary transition-colors line-clamp-1">
          {next.title}
        </span>
      </a>
    )}
  </nav>
  {backLink && (
    <div class="mt-4 text-center">
      <a href={backLink.href} class="text-sm text-text-secondary hover:text-primary transition-colors">
        ← {backLink.label}
      </a>
    </div>
  )}
</footer>
